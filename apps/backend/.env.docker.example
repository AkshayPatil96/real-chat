# ==================================
# Docker Environment Variables
# ==================================
# Copy this file to .env.docker and fill in your Clerk credentials

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Sentry (Optional)
SENTRY_DSN=

# Note: MongoDB and Redis URLs are configured in docker-compose.yml
# No need to set them here unless you're using external services
