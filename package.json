{
  "name": "chat-app-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:backend": "pnpm --filter=backend dev",
    "dev:web": "pnpm --filter=web dev",
    "dev:mobile": "pnpm --filter=mobile dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.8.20",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
